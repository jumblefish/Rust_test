use bevy::prelude::*;

fn main() {
    App::new()
        // DefaultPlugins includes the AssetServer and GLTF loader
        .add_plugins(DefaultPlugins)
        .add_systems(Startup, (setup_scene, load_model))
        .run();
}

/// Sets up the environment: Camera and Lighting
fn setup_scene(mut commands: Commands) {
    // Light
    commands.spawn(PointLightBundle {
        point_light: PointLight {
            intensity: 2000.0,
            shadows_enabled: true,
            ..default()
        },
        transform: Transform::from_xyz(4.0, 8.0, 4.0),
        ..default()
    });

    // Camera
    commands.spawn(Camera3dBundle {
        transform: Transform::from_xyz(-2.5, 4.5, 9.0).looking_at(Vec3::ZERO, Vec3::Y),
        ..default()
    });
}

/// Imports and spawns the 3D object
fn load_model(mut commands: Commands, asset_server: Res<AssetServer>) {
    // Load the GLTF/GLB file from the 'assets' folder
    // Note: The "#Scene0" label tells Bevy to spawn the actual scene within the GLTF
    let model_handle = asset_server.load("my_model.glb#Scene0");

    commands.spawn(SceneBundle {
        scene: model_handle,
        transform: Transform::from_xyz(0.0, 0.0, 0.0),
        ..default()
    });

    println!("Model loading initiated...");
}
