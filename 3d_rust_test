use bevy::prelude::*;
use crossbeam_channel::{unbounded, Receiver, Sender};
use rfd::FileDialog;
use std::path::PathBuf;

// A Resource to hold the communication channel
#[derive(Resource)]
struct FileTaskChannel {
    receiver: Receiver<PathBuf>,
    sender: Sender<PathBuf>,
}

fn main() {
    let (sender, receiver) = unbounded();

    App::new()
        .add_plugins(DefaultPlugins)
        .insert_resource(FileTaskChannel { receiver, sender })
        .add_systems(Startup, setup_scene)
        .add_systems(Update, (trigger_file_dialog, handle_file_selection))
        .run();
}

fn setup_scene(mut commands: Commands) {
    commands.spawn(PointLightBundle {
        point_light: PointLight { intensity: 5000.0, ..default() },
        transform: Transform::from_xyz(4.0, 8.0, 4.0),
        ..default()
    });

    commands.spawn(Camera3dBundle {
        transform: Transform::from_xyz(5.0, 5.0, 10.0).looking_at(Vec3::ZERO, Vec3::Y),
        ..default()
    });
}

/// Listens for the 'Space' key to open the dialog
fn trigger_file_dialog(keys: Res<ButtonInput<KeyCode>>, channels: Res<FileTaskChannel>) {
    if keys.just_pressed(KeyCode::Space) {
        let sender = channels.sender.clone();
        
        // Spawn the dialog in a separate thread to avoid freezing the game
        std::thread::spawn(move || {
            if let Some(path) = FileDialog::new()
                .add_filter("GLTF Models", &["glb", "gltf"])
                .pick_file() 
            {
                let _ = sender.send(path);
            }
        });
    }
}

/// Checks the channel for new paths and loads the model
fn handle_file_selection(
    mut commands: Commands,
    channels: Res<FileTaskChannel>,
    asset_server: Res<AssetServer>,
    current_models: Query<Entity, With<Handle<Scene>>>,
) {
    if let Ok(path) = channels.receiver.try_recv() {
        // Despawn previous models to keep the scene clean
        for entity in &current_models {
            commands.entity(entity).despawn_recursive();
        }

        // Load from absolute path using Gltf loader
        // Note: For runtime loading, Bevy usually looks in the 'assets' folder.
        // For external paths, we convert the path to a string Bevy can use.
        let path_str = path.to_string_lossy();
        let model_handle = asset_server.load(format!("{}#Scene0", path_str));

        commands.spawn(SceneBundle {
            scene: model_handle,
            ..default()
        });
        
        println!("Loading: {}", path_str);
    }
}
